<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF0A1A0E">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="PrivacyGuard Pro"
            android:textSize="24sp"
            android:textColor="#FF4CAF50"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Root版 · 应用层+系统级隐私保护 · LSPosed+Shizuku"
            android:textSize="12sp"
            android:textColor="#99FFFFFF"
            android:gravity="center"
            android:paddingBottom="12dp" />

        <!-- Shizuku 状态 -->
        <TextView
            android:id="@+id/tvShizukuStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#FF4CAF50"
            android:background="#11FFFFFF"
            android:padding="8dp"
            android:gravity="center" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22FFFFFF"
            android:layout_marginVertical="12dp" />

        <!-- ===== 应用层 Hook ===== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="【应用层 Hook】（无需 Root）"
            android:textSize="14sp"
            android:textColor="#FF4CAF50"
            android:textStyle="bold"
            android:paddingBottom="4dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swDeviceId"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="设备ID伪造（IMEI/ANDROID_ID/MAC/Serial）"
            android:textColor="#FFFFFFFF"
            android:checked="true" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swClipboard"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:text="剪贴板保护（记录读取）"
            android:textColor="#FFFFFFFF"
            android:checked="true" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swClipboardBlock"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:text="  阻断剪贴板读取"
            android:textColor="#99FFFFFF"
            android:checked="false" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swPermission"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:text="权限欺骗（仅欺骗APP自身检查）"
            android:textColor="#FFFFFFFF"
            android:checked="false" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swLocation"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:text="位置伪造（默认上海）"
            android:textColor="#FFFFFFFF"
            android:checked="false" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swSensor"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:text="传感器伪造（防指纹追踪）"
            android:textColor="#FFFFFFFF"
            android:checked="false" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swAdId"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:text="广告ID屏蔽"
            android:textColor="#FFFFFFFF"
            android:checked="true" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22FFFFFF"
            android:layout_marginVertical="12dp" />

        <!-- ===== 系统级 Hook ===== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="【系统级 Hook】（需 Shizuku/Root）"
            android:textSize="14sp"
            android:textColor="#FFFF6B35"
            android:textStyle="bold"
            android:paddingBottom="4dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swSystemProp"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="系统属性伪造（setprop ro.*）"
            android:textColor="#FFFFFFFF"
            android:checked="false" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swGlobalPerm"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:text="全局权限控制（pm revoke）"
            android:textColor="#FFFFFFFF"
            android:checked="false" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="注意：真实回收权限，影响APP所有功能"
            android:textSize="11sp"
            android:textColor="#FFFF6B35"
            android:paddingStart="40dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swNetworkId"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:text="网络标识伪造（网卡 MAC）"
            android:textColor="#FFFFFFFF"
            android:checked="false" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swShizukuBridge"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:text="Shizuku 桥接（settings put）"
            android:textColor="#FFFFFFFF"
            android:checked="false" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swClearTracking"
            android:layout_width="match_parent"
            android:layout_height="36dp"
            android:text="  清理APP追踪数据（pm clear）"
            android:textColor="#99FFFFFF"
            android:checked="false" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="警告：pm clear 会清除登录态，谨慎开启"
            android:textSize="11sp"
            android:textColor="#FFFF6B35"
            android:paddingStart="40dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22FFFFFF"
            android:layout_marginVertical="16dp" />

        <!-- 操作按钮区 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnReset"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="恢复默认"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="保存配置" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="32dp" />

    </LinearLayout>
</ScrollView>
