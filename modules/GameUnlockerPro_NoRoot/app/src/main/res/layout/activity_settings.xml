<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF0A0A1A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 机型伪装 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="机型伪装"
            android:textSize="16sp"
            android:textColor="#FF00E5FF"
            android:textStyle="bold"
            android:paddingBottom="4dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swDeviceSpoof"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="开启（仅对本游戏生效）"
            android:textColor="#FFFFFFFF"
            android:checked="true" />

        <Spinner
            android:id="@+id/spProfile"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/edit_bg"
            android:layout_marginTop="4dp" />

        <Button
            android:id="@+id/btnCustomDevice"
            android:layout_width="wrap_content"
            android:layout_height="40dp"
            android:text="自定义机型"
            android:textSize="12sp"
            android:layout_marginTop="4dp"
            style="@style/Widget.MaterialComponents.Button.TextButton" />

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#22FFFFFF" android:layout_marginVertical="12dp" />

        <!-- 帧率解锁 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="帧率解锁"
            android:textSize="16sp"
            android:textColor="#FF00E5FF"
            android:textStyle="bold"
            android:paddingBottom="4dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swFrameRate"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="强制解锁帧率上限"
            android:textColor="#FFFFFFFF"
            android:checked="true" />

        <Spinner
            android:id="@+id/spTargetFps"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/edit_bg"
            android:layout_marginTop="4dp" />

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#22FFFFFF" android:layout_marginVertical="12dp" />

        <!-- 环境隐藏 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="环境隐藏"
            android:textSize="16sp"
            android:textColor="#FF00E5FF"
            android:textStyle="bold"
            android:paddingBottom="4dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swDetectionHide"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="隐藏Xposed/Shizuku/模块痕迹"
            android:textColor="#FFFFFFFF"
            android:checked="true" />

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#22FFFFFF" android:layout_marginVertical="12dp" />

        <!-- 分辨率伪装 -->
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swResolutionSpoof"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="分辨率伪装（低分屏伪装2K）"
            android:textColor="#FFFFFFFF"
            android:checked="false" />

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#22FFFFFF" android:layout_marginVertical="12dp" />

        <!-- 进程优化 -->
        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swProcessOptimize"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:text="进程性能优化（提升渲染优先级+冻结后台）"
            android:textColor="#FFFFFFFF"
            android:checked="true" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="注意：仅应用层优化，不能关闭内核温控"
            android:textSize="11sp"
            android:textColor="#66FFFFFF"
            android:paddingStart="40dp" />

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="#22FFFFFF" android:layout_marginVertical="16dp" />

        <!-- 操作按钮 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnReset"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="恢复默认"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="保存配置" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="32dp" />

    </LinearLayout>
</ScrollView>
