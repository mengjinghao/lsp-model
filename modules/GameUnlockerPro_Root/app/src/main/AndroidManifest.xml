<?xml version="1.0" encoding="utf-8"?>
<!--
  Game-Unlocker Pro - 超强游戏帧率解锁XP模块
  适配LSPatch本地模式免Root运行
  兼容Android 12 ~ Android 15
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Shizuku权限（本地模式通过LSPatch注入时不需要声明，此处保留兼容集成模式） -->
    <uses-permission android:name="moe.shizuku.manager.permission.API_V23"
        tools:ignore="MissingPermission" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.GameUnlockerPro">

        <!-- 设置面板主界面 -->
        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:launchMode="singleTop">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- 游戏独立配置详情页 -->
        <activity
            android:name=".ui.SettingsActivity"
            android:exported="false"
            android:label="@string/settings_title" />

        <!-- Xposed模块声明（LSPatch本地模式识别） -->
        <meta-data
            android:name="xposedmodule"
            android:value="true" />
        <meta-data
            android:name="xposedminversion"
            android:value="82" />
        <meta-data
            android:name="xposeddescription"
            android:value="Game-Unlocker Pro - 全局机型伪装+帧率解锁+温控屏蔽+环境隐藏" />
        <meta-data
            android:name="xposedscope"
            android:resource="@array/xposed_scope" />

    </application>

</manifest>
