<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF1A0E0E"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="22sp"
            android:textColor="#FFFF5722"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="NoRoot版 · LSPatch本地模式 · 仅拦截本APP进程内广告"
            android:textSize="11sp"
            android:textColor="#99FFFFFF"
            android:gravity="center"
            android:paddingBottom="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="已拦截次数：0"
            android:id="@+id/tvBlockedCount"
            android:textSize="13sp"
            android:textColor="#FFFFC107"
            android:gravity="center"
            android:paddingBottom="12dp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="拦截功能开关"
            android:textSize="15sp"
            android:textColor="#FFFFFFFF"
            android:textStyle="bold"
            android:padding="8dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swWebView"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="WebView 广告拦截"
            android:textColor="#FFFFFFFF"
            android:paddingHorizontal="8dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swOkHttp"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="OkHttp 请求拦截"
            android:textColor="#FFFFFFFF"
            android:paddingHorizontal="8dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swUrlConn"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="URLConnection 拦截"
            android:textColor="#FFFFFFFF"
            android:paddingHorizontal="8dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swHosts"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="内存 hosts 黑名单"
            android:textColor="#FFFFFFFF"
            android:paddingHorizontal="8dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swAdView"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="广告 SDK View 隐藏"
            android:textColor="#FFFFFFFF"
            android:paddingHorizontal="8dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swInjectJs"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="注入 JS 隐藏广告 DOM (实验)"
            android:textColor="#FFFFFFFF"
            android:paddingHorizontal="8dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFFFFF"
            android:layout_marginVertical="12dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="黑名单管理"
            android:textSize="15sp"
            android:textColor="#FFFFFFFF"
            android:textStyle="bold"
            android:padding="8dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swBuiltin"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="启用内置黑名单 (60+ 条)"
            android:textColor="#FFFFFFFF"
            android:paddingHorizontal="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="自定义广告域名（一行一个，支持子域名匹配）"
            android:textSize="12sp"
            android:textColor="#CCFFFFFF"
            android:padding="8dp" />

        <EditText
            android:id="@+id/etCustomList"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            android:hint="例如：\nad.example.com\ntracker.example.com"
            android:textColor="#FFFFFFFF"
            android:textColorHint="#66FFFFFF"
            android:textSize="12sp"
            android:gravity="top|start"
            android:background="#FF2A1414"
            android:padding="10dp"
            android:inputType="textMultiLine"
            android:scrollbars="vertical" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#33FFFFFF"
            android:layout_marginVertical="12dp" />

        <androidx.appcompat.widget.SwitchCompat
            android:id="@+id/swLog"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="启用日志输出 (adb logcat -s AdBlockerX:V)"
            android:textColor="#FFFFFFFF"
            android:paddingHorizontal="8dp" />

        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="保存配置"
            android:layout_marginTop="16dp" />

        <Button
            android:id="@+id/btnReset"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="恢复默认"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btnResetCount"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="清零拦截计数"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="说明：NoRoot 版仅拦截本APP进程内网络请求，绝不修改系统hosts/DNS，不影响其他APP。"
            android:textSize="11sp"
            android:textColor="#88FFFFFF"
            android:padding="16dp"
            android:gravity="center" />

    </LinearLayout>
</ScrollView>
