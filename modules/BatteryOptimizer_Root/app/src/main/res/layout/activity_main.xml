<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF0A1A0A">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- 标题 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="24sp"
            android:textColor="#FF66BB6A"
            android:textStyle="bold"
            android:gravity="center"
            android:padding="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="应用层 + 系统级省电优化"
            android:textSize="13sp"
            android:textColor="#99FFFFFF"
            android:gravity="center"
            android:paddingBottom="16dp" />

        <!-- 当前包名显示 -->
        <TextView
            android:id="@+id/tvPkg"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#66FFFFFF"
            android:padding="8dp"
            android:background="#11FFFFFF"
            android:gravity="center" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22FFFFFF"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <!-- 应用层优化章节 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_app_opts"
            android:textSize="16sp"
            android:textColor="#FFFFFFFF"
            android:textStyle="bold"
            android:padding="8dp" />

        <LinearLayout
            android:id="@+id/appSwitchContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22FFFFFF"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <!-- 系统级优化章节 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_sys_opts"
            android:textSize="16sp"
            android:textColor="#FF66BB6A"
            android:textStyle="bold"
            android:padding="8dp" />

        <LinearLayout
            android:id="@+id/sysSwitchContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22FFFFFF"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <!-- 作用域 APP 列表 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_scope"
            android:textSize="16sp"
            android:textColor="#FFFFFFFF"
            android:textStyle="bold"
            android:padding="8dp" />

        <LinearLayout
            android:id="@+id/appListLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#22FFFFFF"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp" />

        <!-- 添加自定义包名 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/title_custom"
            android:textSize="14sp"
            android:textColor="#FFFFFFFF"
            android:padding="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <EditText
                android:id="@+id/etCustomPkg"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:hint="@string/hint_custom_pkg"
                android:textColor="#FFFFFFFF"
                android:textColorHint="#66FFFFFF"
                android:background="@drawable/edit_bg"
                android:paddingHorizontal="12dp"
                android:inputType="textUri" />

            <Button
                android:id="@+id/btnAddCustom"
                android:layout_width="80dp"
                android:layout_height="48dp"
                android:text="@string/btn_add_app"
                android:textSize="13sp"
                android:layout_marginStart="8dp"
                style="@style/Widget.MaterialComponents.Button" />
        </LinearLayout>

        <!-- 操作按钮区 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="24dp">

            <Button
                android:id="@+id/btnReset"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="@string/btn_reset"
                android:textSize="12sp"
                android:layout_marginEnd="4dp"
                style="@style/Widget.MaterialComponents.Button" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="@string/btn_save"
                android:textSize="12sp"
                style="@style/Widget.MaterialComponents.Button" />
        </LinearLayout>

        <!-- 底部说明 -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/footer_note"
            android:textSize="11sp"
            android:textColor="#66FFFFFF"
            android:gravity="center"
            android:padding="16dp"
            android:layout_marginTop="16dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="32dp" />

    </LinearLayout>
</ScrollView>
