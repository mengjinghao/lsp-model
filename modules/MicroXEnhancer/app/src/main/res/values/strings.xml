<resources>
    <!-- 微信 -->
    <string name="wechat_package">com.tencent.mm</string>
    <!-- QQ -->
    <string name="qq_package">com.tencent.mobileqq</string>

    <string-array name="xposed_scope">
        <item>com.tencent.mm</item>
        <item>com.tencent.mobileqq</item>
    </string-array>

    <string name="app_name">微X增强</string>
    <string name="settings_title">微X增强设置</string>

    <!-- 功能分组标题 -->
    <string name="group_ad_block">广告净化</string>
    <string name="group_message">消息增强</string>
    <string name="group_ui">界面美化</string>
    <string name="group_privacy">隐私增强</string>
    <string name="group_batch">批量管理</string>
    <string name="group_security">安全适配</string>

    <!-- 广告净化 -->
    <string name="ad_splash">拦截开屏广告</string>
    <string name="ad_splash_desc">拦截微信/QQ启动时的开屏广告和引导页</string>
    <string name="ad_moments">拦截朋友圈广告</string>
    <string name="ad_moments_desc">过滤朋友圈信息流中的推广动态</string>
    <string name="ad_official_account">拦截公众号广告</string>
    <string name="ad_official_account_desc">屏蔽公众号文章内嵌广告和底部推荐</string>
    <string name="ad_mini_program">拦截小程序广告</string>
    <string name="ad_mini_program_desc">屏蔽小程序弹窗广告和激励视频</string>
    <string name="ad_chat_card">移除聊天页推广卡片</string>
    <string name="ad_chat_card_desc">屏蔽聊天页商品推荐、直播推送、游戏广告</string>

    <!-- 消息增强 -->
    <string name="anti_recall">消息防撤回</string>
    <string name="anti_recall_desc">拦截撤回接口，完整保存已撤回的文字、图片、语音、文件</string>
    <string name="anti_delete_moment">防删朋友圈</string>
    <string name="anti_delete_moment_desc">好友删除的朋友圈动态本地缓存，不会直接消失</string>
    <string name="message_backup">消息本地备份</string>
    <string name="message_backup_desc">单独导出单聊/群聊全部图文记录到本地存储</string>
    <string name="auto_reply">关键词自动回复</string>
    <string name="auto_reply_desc">支持多组自定义话术，区分好友和群聊场景</string>

    <!-- 界面美化 -->
    <string name="custom_bubble">自定义聊天气泡</string>
    <string name="custom_bubble_desc">替换默认聊天气泡样式，支持多个预设主题</string>
    <string name="custom_font">全局字体大小调节</string>
    <string name="custom_font_desc">独立设置微信/QQ的全局字体大小</string>
    <string name="hide_red_dot">一键隐藏小红点</string>
    <string name="hide_red_dot_desc">隐藏朋友圈、群聊、公众号、服务通知所有未读红点</string>
    <string name="remove_tab">去除底部多余Tab</string>
