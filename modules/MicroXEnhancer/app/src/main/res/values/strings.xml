    <string name="force_original">强制原图发送</string>
    <string name="force_original_desc">关闭图片自动压缩，始终以原图画质发送</string>
    <string name="no_watermark_save">无水印保存</string>
    <string name="no_watermark_save_desc">图片/视频一键保存到本地，自动去除平台水印</string>

    <!-- 批量管理 -->
    <string name="one_key_clean">一键清理缓存</string>
    <string name="one_key_clean_desc">清理微信/QQ缓存、聊天图片、短视频，保留聊天记录</string>
    <string name="export_friends">批量导出好友列表</string>
    <string name="export_friends_desc">导出好友名单至Excel/CSV文件以便备份</string>
    <string name="zombie_check">僵尸粉检测</string>
    <string name="zombie_check_desc">批量标记已删除/拉黑你的单向好友</string>
    <string name="group_manage">群聊管理</string>
    <string name="group_manage_desc">批量禁言、屏蔽指定成员发言、关键词过滤垃圾消息</string>

    <!-- 安全适配 -->
    <string name="bypass_detection">绕过安全检测</string>
    <string name="bypass_detection_desc">Hook安全检测类，屏蔽Xposed/LSPatch/LSPatch进程特征识别</string>

    <!-- 通用 -->
    <string name="master_switch">模块总开关</string>
    <string name="master_switch_desc">关闭后所有Hook功能立即失效，无需重启</string>
    <string name="config_export">导出配置</string>
    <string name="config_import">导入配置</string>
    <string name="config_export_desc">将当前所有设置导出为备份文件</string>
    <string name="config_import_desc">从备份文件恢复设置</string>
    <string name="restart_required">部分设置需要重启微信/QQ后生效</string>
    <string name="toast_saved">设置已保存</string>
    <string name="toast_exported">配置已导出到 %s</string>
    <string name="toast_imported">配置导入成功，请重启应用生效</string>
